# Files to be ignored by Git.

*.class

/core
/jcgo
/jcgo-*
/jcgo.exe
/jcgo.jar

/.build_tmp/
/auxbin/
/bin/
/dlls/
/libs/
/rflg_out/
/sawt_out/

/classpath-0.93

/*.tar
/*.tar.bz2
/*.tar.gz

/.checkstyle
/.claude/
/.codepro/
/.project
/.settings/

# MSVC-side build leftovers when probe / harness binaries are run
# from the repo root rather than .build_tmp/.
/*.obj
/*.pdb
/*.stk
/*.ilk
/*.exp
/*.lib
